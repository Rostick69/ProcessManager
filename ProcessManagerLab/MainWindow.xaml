<Window x:Class="ProcessManagerLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Диспетчер процессов - Лабораторная 2" 
        Height="850" Width="1250">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <!-- Дерево процессов -->
            <ColumnDefinition Width="*"/>
            <!-- Таблица + подробности -->
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Кнопки сверху -->
            <RowDefinition Height="*"/>
            <!-- Основная область -->
            <RowDefinition Height="Auto"/>
            <!-- Подробности снизу -->
        </Grid.RowDefinitions>

        <!-- ==================== КНОПКИ СВЕРХУ ==================== -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnRefresh" 
                    Content="Обновить список" 
                    Width="150" 
                    Height="30" 
                    Click="btnRefresh_Click"/>

            <TextBlock VerticalAlignment="Center" Margin="15,0,5,0">Процессов найдено:</TextBlock>
            <TextBlock x:Name="tbCount" 
                       VerticalAlignment="Center" 
                       FontWeight="Bold" 
                       FontSize="14"/>
        </StackPanel>

        <!-- ==================== ДЕРЕВО ПРОЦЕССОВ (слева) ==================== -->
        <TreeView x:Name="tvProcessTree" 
                  Grid.Row="1" 
                  Grid.Column="0" 
                  Margin="0,0,10,0" 
                  FontSize="13"/>

        <!-- ==================== ТАБЛИЦА ПРОЦЕССОВ (справа) ==================== -->
        <DataGrid x:Name="dgProcesses" 
                  Grid.Row="1" 
                  Grid.Column="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionChanged="dgProcesses_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID"        Binding="{Binding Id}"              Width="80"/>
                <DataGridTextColumn Header="Имя"        Binding="{Binding Name}"            Width="200"/>
                <DataGridTextColumn Header="Приоритет"  Binding="{Binding PriorityString}"  Width="110"/>
                <DataGridTextColumn Header="Память, МБ" Binding="{Binding MemoryUsage}"     Width="100"/>
                <DataGridTextColumn Header="Потоков"    Binding="{Binding ThreadCount}"     Width="80"/>
                <DataGridTextColumn Header="Время CPU"  Binding="{Binding CpuTime, StringFormat=hh\\:mm\\:ss}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ==================== ПОДРОБНОСТИ (снизу) ==================== -->
        <GroupBox Grid.Row="2" 
                  Grid.ColumnSpan="2" 
                  Header="Выбранный процесс" 
                  Margin="0,15,0,0" 
                  Padding="12">

            <StackPanel>

                <!-- Основная информация -->
                <TextBlock x:Name="tbSelectedInfo" 
                           Text="Выберите процесс в таблице или в дереве" 
                           FontSize="14" 
                           Margin="0,0,0,12"/>

                <!-- Приоритет -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Новый приоритет:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>
                    <ComboBox x:Name="cbPriority" 
                              Width="170" 
                              Height="30" 
                              Margin="0,0,10,0"
                              DisplayMemberPath="Key"
                              SelectedValuePath="Value"/>
                    <Button x:Name="btnSetPriority" 
                            Content="Применить" 
                            Width="110" 
                            Height="30" 
                            Click="btnSetPriority_Click"/>
                </StackPanel>

                <!-- CPU Affinity -->
                <GroupBox Header="CPU Affinity (привязка к ядрам)" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="tbAffinityInfo" 
                                   Text="Текущая маска: ..." 
                                   Margin="0,0,0,8" 
                                   FontWeight="Bold"/>
                        <StackPanel x:Name="spCores" 
                                    Orientation="Horizontal" 
                                    Margin="0,0,0,10"/>
                        <Button x:Name="btnApplyAffinity" 
                                Content="Применить привязку к ядрам" 
                                Width="230" 
                                Click="btnApplyAffinity_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Потоки -->
                <GroupBox Header="Потоки процесса">
                    <DataGrid x:Name="dgThreads" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              Height="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thread ID"   Binding="{Binding Id}" Width="90"/>
                            <DataGridTextColumn Header="Приоритет"   Binding="{Binding Priority}" Width="130"/>
                            <DataGridTextColumn Header="Состояние"   Binding="{Binding State}" Width="110"/>
                            <DataGridTextColumn Header="Время CPU"   Binding="{Binding CpuTime, StringFormat=hh\\:mm\\:ss}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

            </StackPanel>
        </GroupBox>
    </Grid>
</Window>